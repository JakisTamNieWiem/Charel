{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "charel",
  "version": "2.1.1",
  "identifier": "com.jtnw.charel",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "decorations": false,
        "fullscreen": false,
        "title": "Charel",
        "width": 1280,
        "height": 720,
        "minHeight": 800,
        "minWidth": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "windows": {
        "installMode": "passive"
      },
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJGQjlEMDBBNUY2MUU1QkIKUldTNzVXRmZDdEM1THp0Q3FOR2tjL2pYL0EvYTVOSGdrS0lCNUcxM1dRM2QreTRURVFYZEExaU4K",
      "endpoints": [
        "https://github.com/JakisTamNieWiem/Charel/releases/latest/download/latest.json"
      ]
    }
  }
}

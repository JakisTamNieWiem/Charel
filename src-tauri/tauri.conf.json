{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "charel",
  "version": "1.0.0",
  "identifier": "com.jtnw.charel",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "charel",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENDRTBCRjMyRjU4QjgzQTgKUldTb2c0djFNci9nekFQR2g5elhDWmF0c2phWGowcm0wTDlmU2luUmhLWDVCTmFnN1ptR3FCSkwK",
      "endpoints": [
        "https://github.com/JakisTamNieWiem/Charel/releases/latest/download/latest.json"
      ]
    }
  }
}
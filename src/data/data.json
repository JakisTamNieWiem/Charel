    {
      "fromId": "char-11",
      "toId": "char-17",
      "typeId": "6c9f04eb-e037-4656-ba35-36bd51ff28b7",
      "description": "Siostra Jakuba. Szkoda jej tego, że ta musiała skończyć tak a nie inaczej."
    },
    {
      "fromId": "char-11",
      "toId": "char-7",
      "typeId": "friend",
      "description": "Można na nim polegać. Świetny kompan i miła osoba."
    },
    {
      "fromId": "char-11",
      "toId": "char-18",
      "typeId": "1fc6de78-7361-498e-bd98-160cf09dd707",
      "description": "Za dzieciaka bardzo dużo jej dokuczała. Zdaje się, że trochę już z tego wyrosła ale dalej ma odruchy gdy ta robi jakieś nagłe ruchy. Kocha ją, ale nie czuje się przy niej bezpiecznie."
    },
    {
      "fromId": "char-11",
      "toId": "char-23",
      "typeId": "friend",
      "description": "Uwielbia sięz nim bawić. W wolnym czasie go wyprowadza."
    },
    {
      "fromId": "char-11",
      "toId": "char-25",
      "typeId": "74054232-6a56-4154-a662-cbae04858962",
      "description": "Specyficzna osoba. Nie potrafi jejo rozgryść, ale robi co w jej mocy."

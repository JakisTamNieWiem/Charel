      "fromId": "char-11",
      "toId": "char-28",
      "typeId": "6c9f04eb-e037-4656-ba35-36bd51ff28b7",
      "description": "Troche straszny."
    },
    {
      "fromId": "char-11",
      "toId": "char-29",
      "typeId": "friend",
      "description": "Ta zdaje się być jej bardzo blisko. Wybuchowa. Ma specyficzne pomysły, ale zdaje się dobrze bawić koniec końców."
